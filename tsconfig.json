{
  "extends": ["astro/tsconfigs/strict", "@vue/tsconfig/tsconfig.dom.json", "@tsconfig/strictest"],
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "plugins": [
      {
        "name": "@astrojs/ts-plugin"
      }
    ],
    "jsx": "preserve"
  }
}
